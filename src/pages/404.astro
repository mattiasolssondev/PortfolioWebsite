---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found">
  <div class="mx-auto max-w-lg px-4 py-24 text-center sm:px-6">
    <p class="font-display text-6xl font-bold text-accent">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold text-white">Page not found</h1>
    <p class="mt-2 text-muted">That game or page doesn't exist.</p>
    <a
      href="/"
      class="mt-8 inline-block rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-dim"
    >
      Back to games
    </a>
  </div>
</BaseLayout>
