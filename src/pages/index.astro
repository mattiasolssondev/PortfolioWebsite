---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameGrid from '../components/GameGrid.astro';
import { getCollection } from 'astro:content';

const allGames = await getCollection('games', ({ data }) => data.status !== 'archived');
const games = allGames.sort(
  (a, b) => b.data.releasedAt.getTime() - a.data.releasedAt.getTime(),
);
const featured = games.find((g) => g.data.featured && g.data.status === 'released');
---

<BaseLayout title="Playframe">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <section class="mb-14">
      <p class="mb-2 text-sm font-medium uppercase tracking-widest text-accent">
        Unity WebGL portfolio
      </p>
      <h1 class="font-display text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Games I build in Unity
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">
        Playframe showcases WebGL games hosted on Unity Play — embedded right
        here, no downloads required.
      </p>
    </section>

    {
      featured && (
        <section class="mb-14">
          <h2 class="mb-4 font-display text-sm font-semibold uppercase tracking-widest text-muted">
            Featured
          </h2>
          <a
            href={`/games/${featured.id}`}
            class="card-glow group flex flex-col overflow-hidden rounded-2xl border border-border bg-surface-raised sm:flex-row"
          >
            <div class="aspect-video overflow-hidden sm:w-1/2">
              <img
                src={featured.data.thumbnail}
                alt={featured.data.title}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                width="800"
                height="450"
              />
            </div>
            <div class="flex flex-col justify-center gap-3 p-6 sm:w-1/2 sm:p-8">
              <h3 class="font-display text-2xl font-bold text-white">
                {featured.data.title}
              </h3>
              <p class="text-muted">{featured.data.description}</p>
              <span class="mt-2 text-sm font-medium text-accent">
                Play now →
              </span>
            </div>
          </a>
        </section>
      )
    }

    <section>
      <h2 class="mb-6 font-display text-sm font-semibold uppercase tracking-widest text-muted">
        All games
      </h2>
      <GameGrid games={games} />
    </section>
  </div>
</BaseLayout>
