---
import GameLayout from '../../layouts/GameLayout.astro';
import UnityPlayEmbed from '../../components/UnityPlayEmbed.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const games = await getCollection('games', ({ data }) => data.status === 'released');
  return games.map((game) => ({
    params: { slug: game.id },
  }));
}

const { slug } = Astro.params;
const game = await getEntry('games', slug!);

if (!game) {
  return Astro.redirect('/404');
}

const { Content } = await render(game);

const {
  title,
  description,
  unityPlayUrl,
  embedUrl,
  screenshots,
  tags,
  releasedAt,
  engine,
  platform,
  unityVersion,
  playTime,
} = game.data;

const formattedDate = releasedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const allGames = await getCollection('games', ({ data }) => data.status === 'released');
const related = allGames
  .filter((g) => g.id !== slug && g.data.tags.some((t) => tags.includes(t)))
  .slice(0, 3);
---

<GameLayout title={title} description={description}>
  <article class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-14">
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-1 text-sm text-muted transition-colors hover:text-accent"
    >
      ← All games
    </a>

    <header class="mb-8">
      <h1 class="font-display text-3xl font-bold text-white sm:text-4xl">
        {title}
      </h1>
      <p class="mt-3 text-lg text-muted">{description}</p>
      <dl class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted">
        <div>
          <dt class="inline">Released </dt>
          <dd class="inline text-white">{formattedDate}</dd>
        </div>
        <div>
          <dt class="inline">Engine </dt>
          <dd class="inline text-white">{engine}</dd>
        </div>
        <div>
          <dt class="inline">Platform </dt>
          <dd class="inline text-white">{platform}</dd>
        </div>
        {
          unityVersion && (
            <div>
              <dt class="inline">Unity </dt>
              <dd class="inline text-white">{unityVersion}</dd>
            </div>
          )
        }
        {
          playTime && (
            <div>
              <dt class="inline">Play time </dt>
              <dd class="inline text-white">{playTime}</dd>
            </div>
          )
        }
      </dl>
      {
        tags.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li class="rounded-md border border-border bg-surface-raised px-2.5 py-1 text-xs text-muted">
                {tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    {
      embedUrl && (
        <section class="mb-10">
          <UnityPlayEmbed
            embedUrl={embedUrl}
            unityPlayUrl={unityPlayUrl}
            title={title}
          />
        </section>
      )
    }

    <section
      class="prose prose-invert max-w-none prose-headings:font-display prose-a:text-accent"
    >
      <Content />
    </section>

    {
      screenshots.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-4 font-display text-lg font-semibold text-white">
            Screenshots
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {screenshots.map((src) => (
              <img
                src={src}
                alt={`${title} screenshot`}
                class="rounded-lg border border-border"
                loading="lazy"
                width="1280"
                height="720"
              />
            ))}
          </div>
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="mt-14 border-t border-border pt-10">
          <h2 class="mb-4 font-display text-lg font-semibold text-white">
            Related games
          </h2>
          <ul class="space-y-2">
            {related.map((g) => (
              <li>
                <a
                  href={`/games/${g.id}`}
                  class="text-accent transition-colors hover:text-white"
                >
                  {g.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</GameLayout>
