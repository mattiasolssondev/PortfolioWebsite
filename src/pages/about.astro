---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About the creator behind Playframe.">
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 sm:py-16">
    <h1 class="font-display text-4xl font-bold text-white">About</h1>
    <div class="mt-6 space-y-4 text-muted">
      <p>
        I build games in Unity and publish them to Unity Play. This site —
        <strong class="text-white">Playframe</strong> — is where I showcase them
        with embedded WebGL playback.
      </p>
      <p>
        Each game runs on Unity Play's infrastructure. Playframe provides the
        portfolio layer: descriptions, screenshots, and a dark-themed home for
        everything I make.
      </p>
      <p>
        <a
          href="https://github.com/mattiasolssondev"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-accent transition-colors hover:text-white"
        >
          GitHub ↗
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
