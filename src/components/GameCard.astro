---
import type { CollectionEntry } from 'astro:content';

interface Props {
  game: CollectionEntry<'games'>;
}

const { game } = Astro.props;
const { title, description, thumbnail, tags, status } = game.data;
const href = status === 'coming-soon' ? undefined : `/games/${game.id}`;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'card-glow group flex flex-col overflow-hidden rounded-xl border border-border bg-surface-raised',
    href && 'cursor-pointer',
  ]}
>
  <div class="relative aspect-video overflow-hidden bg-[#0f0f14]">
    <img
      src={thumbnail}
      alt={`${title} thumbnail`}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
      width="800"
      height="450"
    />
    {
      status === 'coming-soon' && (
        <span class="absolute right-3 top-3 rounded-full bg-black/70 px-3 py-1 text-xs font-medium text-accent backdrop-blur-sm">
          Coming soon
        </span>
      )
    }
  </div>
  <div class="flex flex-1 flex-col gap-2 p-4">
    <h2 class="font-display text-lg font-semibold text-white">{title}</h2>
    <p class="line-clamp-2 text-sm text-muted">{description}</p>
    {
      tags.length > 0 && (
        <ul class="mt-auto flex flex-wrap gap-2 pt-2">
          {tags.map((tag) => (
            <li class="rounded-md bg-[#0f0f14] px-2 py-0.5 text-xs text-muted">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</Tag>
